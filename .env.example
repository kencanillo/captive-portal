APP_NAME="KennFi Lab"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Manila
APP_URL=https://portal.kennfilab.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kennfi_lab
DB_USERNAME=kennfi_lab_user
DB_PASSWORD=change_me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_LIMITER=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

PAYMONGO_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx
PAYMONGO_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
PAYMONGO_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
PAYMONGO_BASE_URL=https://api.paymongo.com/v1
PAYMONGO_QRPH_EXPIRY_SECONDS=1800
PAYMONGO_WEBHOOK_TOLERANCE_SECONDS=300
OMADA_VERIFY_SSL=true
OMADA_INTERNAL_BASE_URL=
OMADA_CLAIM_SYNC_MAX_AGE_SECONDS=300
OMADA_HEALTH_SIGNAL_MAX_AGE_SECONDS=180
OMADA_HEALTH_RUNTIME_DEGRADED_AFTER_SECONDS=300
OMADA_BILLING_CONNECTION_FEE_AMOUNT=500
OMADA_BILLING_CONNECTION_FEE_CURRENCY=PHP
OMADA_BILLING_RUNTIME_DEGRADED_AFTER_SECONDS=300
PORTAL_CONTEXT_TOKEN_LIFETIME_MINUTES=10
PORTAL_SESSION_TOKEN_LIFETIME_MINUTES=120
PORTAL_PAYMENT_TOKEN_LIFETIME_MINUTES=180
PORTAL_ALLOW_QUERY_MAC_FALLBACK=false
PORTAL_BOOTSTRAP_TIMEOUT_SECONDS=8
PORTAL_CACHE_STORE=database
PORTAL_DEVICE_CONTEXT_RETRY_AFTER_MS=1500
PORTAL_DEVICE_CONTEXT_POSITIVE_CACHE_SECONDS=300
PORTAL_DEVICE_CONTEXT_MISS_CACHE_SECONDS=3
PORTAL_EWALLET_FEE_RATE=0.02
PORTAL_OMADA_CONNECT_TIMEOUT_SECONDS=1
PORTAL_OMADA_TIMEOUT_SECONDS=4
PORTAL_OMADA_MAC_LOOKUP_CACHE_SECONDS=45
PORTAL_OMADA_CLIENTS_SNAPSHOT_CACHE_SECONDS=5
PAYMONGO_CONNECT_TIMEOUT_SECONDS=2
PAYMONGO_TIMEOUT_SECONDS=4

PAYOUT_MODE=manual
PAYOUT_PROVIDER=paymongo
PAYOUT_CURRENCY=PHP
PAYMONGO_PAYOUTS_ENABLED=false
PAYMONGO_PAYOUT_WALLET_ID=
PAYMONGO_PAYOUT_CALLBACK_URL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
